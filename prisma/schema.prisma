generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User roles ───────────────────────────────────────────────────────────────
enum UserRole {
  ADMIN
  TEAM
  SETTER
  CLIENT
}

// ─── Profile: extends Supabase auth.users ─────────────────────────────────
// Keyed by the Supabase user UUID (as string). One row per auth user.
// clientId: FK directo al workspace asignado (null hasta que admin lo asigne).
model Profile {
  id                String    @id // Supabase auth user UUID
  email             String?
  displayName       String?
  avatarUrl         String?
  instagramUsername String?
  nicho             String?
  role              UserRole  @default(CLIENT)
  themeKey          String    @default("eternity")
  clientId          String?
  client            Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

// ─── Client (tenant workspace) ────────────────────────────────────────────
model Client {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  themeKey      String    @default("eternity")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  profiles      Profile[]
}

// ─── Business tables ──────────────────────────────────────────────────────

model Competitor {
  id             String      @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  username       String
  displayName    String?
  profilePicUrl  String?
  followersCount Int?
  lastScrapedAt  DateTime?
  createdAt      DateTime    @default(now())
  reels          Reel[]
  jobs           ScrapeJob[]

  @@unique([clientId, username])
  @@index([clientId])
}

model Reel {
  id            String         @id @default(cuid())
  clientId      String
  createdBy     String?
  updatedBy     String?
  competitorId  String
  instagramId   String         @unique
  shortcode     String
  url           String
  thumbnailUrl  String?
  videoUrl      String?
  caption       String?
  viewsCount    Int            @default(0)
  likesCount    Int            @default(0)
  commentsCount Int            @default(0)
  sharesCount   Int            @default(0)
  durationSec   Float?
  postedAt      DateTime?
  scrapedAt     DateTime       @default(now())
  analyses      Analysis[]
  chatMessages  ChatMessage[]
  competitor    Competitor     @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  transcription Transcription?

  @@index([clientId])
  @@index([competitorId, viewsCount])
  @@index([competitorId, commentsCount])
  @@index([competitorId, likesCount])
  @@index([competitorId, postedAt])
}

model Transcription {
  id        String   @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  reelId    String   @unique
  text      String
  language  String
  provider  String   @default("groq-whisper-v3-turbo")
  costUsd   Float?
  createdAt DateTime @default(now())
  reel      Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model Analysis {
  id           String   @id @default(cuid())
  clientId     String
  createdBy    String?
  updatedBy    String?
  reelId       String
  model        String
  painPoints   String
  desires      String
  problems     String
  insights     String
  keywords     String
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?
  createdAt    DateTime @default(now())
  reel         Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([reelId, createdAt])
}

model ChatMessage {
  id           String   @id @default(cuid())
  clientId     String
  createdBy    String?
  updatedBy    String?
  reelId       String
  role         String
  content      String
  model        String?
  inputTokens  Int?
  outputTokens Int?
  costUsd      Float?
  createdAt    DateTime @default(now())
  reel         Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([reelId, createdAt])
}

model ScrapeJob {
  id             String      @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  competitorId   String?
  username       String
  requestedCount Int
  actualCount    Int         @default(0)
  status         String
  kind           String      @default("initial")
  apifyRunId     String?
  errorMessage   String?
  costUsd        Float?
  startedAt      DateTime    @default(now())
  completedAt    DateTime?
  competitor     Competitor? @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([status, startedAt])
  @@index([competitorId])
}

model Conversation {
  id        String      @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  title     String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@index([clientId])
  @@index([updatedAt])
}

model AIMessage {
  id             String       @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  conversationId String
  role           String
  content        String
  model          String?
  inputTokens    Int?
  outputTokens   Int?
  costUsd        Float?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([conversationId, createdAt])
}

model SocialConnection {
  id           String    @id @default(cuid())
  clientId     String
  createdBy    String?
  updatedBy    String?
  platform     String
  accountId    String
  accountName  String
  accountPic   String?
  accessToken  String
  refreshToken String?
  expiresAt    DateTime?
  scopes       String    @default("")
  connectedAt  DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([clientId, platform])
  @@index([clientId])
  @@index([platform])
}

model OAuthState {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  state     String   @unique
  platform  String
  returnTo  String   @default("/")
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
}

model Task {
  id          String    @id @default(cuid())
  clientId    String
  createdBy   String?
  updatedBy   String?
  title       String
  description String    @default("")
  dueDate     DateTime?
  labelText   String    @default("")
  labelColor  String    @default("")
  columnId    String    @default("por-hacer")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
  @@index([clientId, columnId])
}

// ContentPiece doubles as CalendarEvent (reels + historias calendar items)
model ContentPiece {
  id          String    @id @default(cuid())
  clientId    String
  createdBy   String?
  updatedBy   String?
  title       String
  description String    @default("")
  type        String    @default("reel")
  status      String    @default("drafts")
  color       String    @default("")
  category    String    @default("")
  date        DateTime?
  endDate     DateTime?
  format      String    @default("")
  platform    String    @default("")
  emoji       String    @default("")
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([clientId])
}

model ContentTemplate {
  id          String   @id @default(cuid())
  clientId    String
  createdBy   String?
  updatedBy   String?
  name        String
  type        String   @default("reel")
  status      String   @default("drafts")
  color       String   @default("")
  category    String   @default("")
  description String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId])
}

model ICPProfile {
  id        String   @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  nombre    String   @default("")
  edad      String   @default("")
  ingresos  String   @default("")
  nicho     String   @default("")
  rol       String   @default("")
  dolores   String   @default("[]")
  deseos    String   @default("[]")
  creencias String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
}

model BusinessBase {
  id        String   @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  key       String
  content   String   @default("")
  items     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([clientId, key])
  @@index([clientId])
}

model Idea {
  id           String   @id @default(cuid())
  clientId     String
  createdBy    String?
  updatedBy    String?
  title        String
  format       String   @default("")
  notes        String   @default("")
  referenceUrl String   @default("")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId])
}

// Guion = script editor. GuionTab + GuionItem together represent "Guion".
model GuionTab {
  id        String      @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  name      String
  type      String      @default("reel")
  emoji     String      @default("")
  order     Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     GuionItem[]

  @@index([clientId])
}

model GuionItem {
  id        String   @id @default(cuid())
  clientId  String
  createdBy String?
  updatedBy String?
  tabId     String
  title     String
  content   String   @default("")
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tab       GuionTab @relation(fields: [tabId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([tabId])
}

// ─── Instagram analytics (client-owned reels + stories + account snapshots) ──

// UserReel = a reel belonging to the client's own IG account
// (contrast with Reel which belongs to a competitor).
model UserReel {
  id             String    @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  instagramId    String    @unique
  shortcode      String
  url            String
  thumbnailUrl   String?
  videoUrl       String?
  caption        String?
  durationSec    Float?
  viewsCount     Int       @default(0)
  viewsOrganic   Int       @default(0)
  viewsPaid      Int       @default(0)
  likesCount     Int       @default(0)
  savesCount     Int       @default(0)
  commentsCount  Int       @default(0)
  sharesCount    Int       @default(0)
  reachCount     Int       @default(0)
  impressions    Int       @default(0)
  organicPercent Float     @default(0)
  multiplier     Float     @default(0)
  isAd           Boolean   @default(false)
  isTrialReel    Boolean   @default(false)
  publishedAt    DateTime?
  syncedAt       DateTime  @default(now())
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([clientId, publishedAt])
  @@index([clientId, viewsCount])
}

model Story {
  id             String    @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  instagramId    String    @unique
  thumbnailUrl   String?
  reach          Int       @default(0)
  impressions    Int       @default(0)
  replies        Int       @default(0)
  stickerTaps    Int       @default(0)
  exits          Int       @default(0)
  completionRate Float     @default(0)
  publishedAt    DateTime?
  syncedAt       DateTime  @default(now())
  createdAt      DateTime  @default(now())

  @@index([clientId, publishedAt])
}

// YouTubeVideo = a video belonging to the client's own YouTube channel.
// Separated from UserReel because YT metrics differ substantially from IG
// (watch time, average view duration, no saves/reach/organicPercent, etc.).
model YouTubeVideo {
  id                  String    @id @default(cuid())
  clientId            String
  createdBy           String?
  updatedBy           String?
  videoId             String    // YouTube video id
  channelId           String
  title               String
  description         String    @default("")
  thumbnailUrl        String?
  url                 String
  durationSec         Int       @default(0)
  durationLabel       String    @default("") // e.g. "12:34"
  viewsCount          Int       @default(0)
  likesCount          Int       @default(0)
  commentsCount       Int       @default(0)
  favoriteCount       Int       @default(0)
  // Analytics fields (filled when YT Analytics API is queried — currently optional)
  watchTimeMinutes    Int?
  averageViewDuration Int? // seconds
  averageViewPercent  Float?
  ctr                 Float?
  publishedAt         DateTime?
  syncedAt            DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([clientId, videoId])
  @@index([clientId, publishedAt])
  @@index([clientId, viewsCount])
  @@index([channelId])
}

model TikTokVideo {
  id           String    @id @default(cuid())
  clientId     String
  createdBy    String?
  updatedBy    String?
  videoId      String    // TikTok video id
  title        String    @default("")
  description  String    @default("")
  coverUrl     String?
  shareUrl     String    @default("")
  durationSec  Int       @default(0)
  viewCount    Int       @default(0)
  likeCount    Int       @default(0)
  commentCount Int       @default(0)
  shareCount   Int       @default(0)
  publishedAt  DateTime?
  syncedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([clientId, videoId])
  @@index([clientId, publishedAt])
  @@index([clientId, viewCount])
}

// AccountSnapshot: daily/periodic rollup of account metrics per client, scoped
// by platform (instagram | youtube | tiktok | ...). The `platform` discriminator
// is what makes this table safe to use for multiple social networks: without
// it, YT sync and IG sync would collide on the `(clientId, date)` key and
// silently overwrite each other — the bug fixed in MC-02.
model AccountSnapshot {
  id             String   @id @default(cuid())
  clientId       String
  createdBy      String?
  updatedBy      String?
  platform       String   @default("instagram")
  date           DateTime
  followers      Int      @default(0)
  following      Int      @default(0)
  posts          Int      @default(0)
  totalViews     Int      @default(0)  // formerly "impressions" — stores sum of video views across all synced media
  reach          Int      @default(0)
  profileVisits  Int      @default(0)
  newFollowers   Int      @default(0)
  engagementRate Float    @default(0)
  createdAt      DateTime @default(now())

  @@unique([clientId, platform, date])
  @@index([clientId, platform, date])
}

// AudienceSnapshot: cached Instagram audience demographics from the Insights API.
// One row per (clientId, platform, date). Refreshed at most once per day.
model AudienceSnapshot {
  id              String   @id @default(cuid())
  clientId        String
  platform        String   @default("instagram")
  date            DateTime
  genderAge       Json     @default("{}")  // { "F.18-24": 12, "M.25-34": 45, ... }
  country         Json     @default("{}")  // { "AR": 120, "US": 80, ... }
  city            Json     @default("{}")  // { "Buenos Aires": 60, ... }
  followerHistory Json     @default("[]") // [{ date: "2024-01-01", value: 5 }, ...]
  reachHistory    Json     @default("[]") // [{ date: "2024-01-01", value: 300 }, ...]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  createdBy       String?
  updatedBy       String?

  @@unique([clientId, platform, date])
  @@index([clientId, platform, date])
}

// ContentResearchHistory: /content-research — saved channel-level research runs.
// Each row stores the channel info + a JSON array of top videos with their AI
// analysis. Ported from Smart-Scale's `content_research_history` table.
model ContentResearchHistory {
  id             String   @id @default(cuid())
  clientId       String
  createdBy      String?
  platform       String   // 'youtube' | 'instagram'
  channelUrl     String
  channelName    String?
  channelAvatar  String?
  timeframeDays  Int      @default(30)
  videos         Json     @default("[]")  // VideoResult[] (see view types)
  createdAt      DateTime @default(now())

  @@index([clientId, createdAt])
}

// VideoFeedAccount: /video-feed — singleton per (client, platform) tracking the
// user's own connected feed (last 30 days, AI-ranked). Ported from Smart-Scale.
// Posts persisted as JSON so we don't bloat the schema with per-post rows for
// every refresh — engagement score + analysis are recomputed in-memory.
model VideoFeedAccount {
  id             String   @id @default(cuid())
  clientId       String
  createdBy      String?
  platform       String   // 'instagram'
  channelUrl     String
  channelName    String?
  channelAvatar  String?
  posts          Json     @default("[]")  // FeedPost[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([clientId, platform])
  @@index([clientId])
}

// TranscriptHistory: /transcript — saved transcriptions of YouTube/IG URLs.
// Ported from Smart-Scale's `transcript_history` table. Stores the URL,
// resolved metadata, full transcript and AI-generated summary so users can
// revisit past analyses without re-running the (paid) transcription pipeline.
model TranscriptHistory {
  id         String   @id @default(cuid())
  clientId   String
  createdBy  String?
  url        String
  platform   String   // 'youtube' | 'instagram'
  title      String?
  creator    String?
  duration   String?
  thumbnail  String?
  transcript String?
  summary    String?
  createdAt  DateTime @default(now())

  @@index([clientId, createdAt])
}

// AdAccount: a connected advertising account (Meta Ads or TikTok Ads).
// One row per (clientId, platform, accountId). Campaigns belong to an account.
model AdAccount {
  id          String       @id @default(cuid())
  clientId    String
  createdBy   String?
  updatedBy   String?
  platform    String       // 'meta'
  accountId   String       // platform's account id (e.g. "act_123456")
  accountName String       @default("")
  currency    String       @default("USD")
  syncedAt    DateTime     @default(now())
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  campaigns   AdCampaign[]

  @@unique([clientId, platform, accountId])
  @@index([clientId, platform])
}

// AdCampaign: snapshot of one campaign's metrics from the last sync.
// Metrics are overwritten on each sync — not time-series.
model AdCampaign {
  id           String    @id @default(cuid())
  clientId     String
  adAccountId  String
  adAccount    AdAccount @relation(fields: [adAccountId], references: [id], onDelete: Cascade)
  platform     String    // 'meta'
  campaignId   String    @unique  // platform's campaign id
  name         String    @default("")
  status       String    @default("UNKNOWN")
  objective    String    @default("")
  spend        Float     @default(0)
  impressions  Int       @default(0)
  clicks       Int       @default(0)
  reach        Int       @default(0)
  ctr          Float     @default(0)
  cpc          Float     @default(0)
  roas         Float     @default(0)
  conversions  Int       @default(0)
  datePreset   String    @default("last_30d")
  syncedAt     DateTime  @default(now())
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([clientId, platform])
  @@index([adAccountId])
  @@index([clientId, spend])
}

// IncomeRecord: /ventas — one income entry, optionally tied to a reel.
model IncomeRecord {
  id          String   @id @default(cuid())
  clientId    String
  createdBy   String?
  updatedBy   String?
  amount      Float
  currency    String   @default("USD")
  source      String   @default("") // e.g. "trial reel", "ads", "referral"
  description String   @default("")
  reelId      String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([clientId, date])
  @@index([clientId, source])
  @@index([reelId])
}

// InstagramComment: cached comments + replies per media (reel/post).
// Synced on demand from GET /api/instagram/comments?mediaId=.
model InstagramComment {
  id         String   @id @default(cuid())
  clientId   String
  mediaId    String   // Instagram media ID (reel/post)
  commentId  String   // Instagram comment ID (unique per account)
  username   String   @default("")
  text       String
  timestamp  DateTime
  likeCount  Int      @default(0)
  hidden     Boolean  @default(false)
  parentId   String?  // set for replies — points to parent commentId on Instagram
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([clientId, commentId])
  @@index([clientId, mediaId])
  @@index([clientId, parentId])
}

// PublishedPost: Instagram content published via the dashboard.
// status: PENDING (container created, not yet published) | PUBLISHED | FAILED
model PublishedPost {
  id           String   @id @default(cuid())
  clientId     String
  createdBy    String?
  containerId  String   @default("") // IG container ID (step 1)
  postId       String   @default("") // IG media ID (after publish)
  mediaType    String   @default("IMAGE") // IMAGE | REEL | CAROUSEL
  mediaUrl     String                      // first/primary url (back-compat)
  mediaUrls    String[] @default([])       // all item urls (single item = [mediaUrl])
  itemTypes    String[] @default([])       // IMAGE | VIDEO per carousel item
  caption      String   @default("")
  status       String   @default("PENDING") // PENDING | PUBLISHED | FAILED
  errorMessage String   @default("") // raw Meta error (last_error)
  permalink    String?  // Instagram post permalink (fetched after publish)
  publishedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([clientId, createdAt])
  @@index([clientId, status])
}

// IGConversation: one row per Instagram DM thread per client.
// Synced every 5 min via Vercel cron → POST /api/instagram/messages/sync
model IGConversation {
  id                  String      @id @default(cuid())
  clientId            String
  conversationId      String      @unique // Instagram conversation ID
  participantId       String      @default("") // other party's Instagram-scoped ID
  participantUsername String      @default("")
  participantPic      String      @default("")
  lastMessageAt       DateTime?
  lastUserMessageAt   DateTime?   // used for 24h window check
  unreadCount         Int         @default(0)
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  messages            IGMessage[]

  @@unique([clientId, conversationId])
  @@index([clientId, lastMessageAt])
}

// IGMessage: individual messages within a conversation.
model IGMessage {
  id             String         @id @default(cuid())
  clientId       String
  conversationId String         // references IGConversation.conversationId
  messageId      String         // Instagram message ID
  fromId         String         @default("")
  fromUsername   String         @default("")
  text           String         @default("")
  isFromBusiness Boolean        @default(false)
  timestamp      DateTime
  createdAt      DateTime       @default(now())
  conversation   IGConversation @relation(fields: [conversationId], references: [conversationId], onDelete: Cascade)

  @@unique([clientId, messageId])
  @@index([clientId, conversationId, timestamp])
}
